# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit .env.docker (contains real secrets)
# Use .env.docker.example as a template: cp .env.docker.example .env.docker
.env*
!.env.example
!.env.docker.example

# Docker Secrets — contains real production secrets
/secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug files
errors.txt
tsc_errors.log
lint_output.txt
eslint_out.txt
tsc_output.txt

/lib/generated/prisma

# debug and test parse artifacts
lint-debug.txt
lint-output*.json
test-parse*.cjs
tsc-output.txt
tsc-pretty.txt
_fix*.cjs

# kilo agents
.kilo/
