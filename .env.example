# ============================================
# HAY2010 Stock Application - Environment Template
# ============================================
# Copy this file to .env for local development
# For Docker deployment, these are set in docker-compose.yml
# ============================================

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/hay2010_db"

POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="hay2010_db"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Authentication
# Generate with: openssl rand -base64 64
JWT_SECRET="your-secure-jwt-secret-here-change-in-production"
JWT_EXPIRES_IN="24h"

# Admin Seed Credentials
# Used by prisma/seed.ts when creating the initial admin user
# Override these in .env or via command line before running seed
SEED_ADMIN_EMAIL="admin@hay2010.com"
SEED_ADMIN_PASSWORD="Admin@2026"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
SECURE_COOKIES="false"

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:3000"
# API CORS (separate, for /api/v1 routes — comma-separated origins)
API_CORS_ORIGINS="http://localhost:3000"

# Optional: Redis Cluster (for production scaling)
# REDIS_CLUSTER_NODES="redis-1:6379,redis-2:6379,redis-3:6379"

# Optional: Monitoring
# SENTRY_DSN="https://xxx@sentry.io/xxx"

# Optional: Email (if implemented later)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
