# Database Configuration
# Main database URL (used by Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/hay2010_db"

# Admin database URL (for create-db.mjs - connects to postgres database)
# This is needed to create the application database if it doesn't exist
DATABASE_ADMIN_URL="postgresql://postgres:your-secure-password-here@localhost:5432/postgres"

POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="hay2010_db"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD - Set this in production for authentication
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=""

# Authentication
# Generate with: openssl rand -base64 64
JWT_SECRET="your-secure-jwt-secret-here-change-in-production"
JWT_EXPIRES_IN="24h"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:3000"

# Optional: Redis Cluster (for production scaling)
# REDIS_CLUSTER_NODES="redis-1:6379,redis-2:6379,redis-3:6379"

# Optional: Monitoring
# SENTRY_DSN="https://xxx@sentry.io/xxx"

# Optional: Email (if implemented later)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
