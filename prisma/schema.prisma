generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// AUTHENTICATION MODELS
// =====================================================
// AUTHENTICATION MODELS
// =====================================================
// AUTHENTICATION MODELS
// =====================================================
// AUTHENTICATION MODELS
// =====================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(HR)
  createdAt DateTime @default(now())

  @@map("users")
}

enum Role {
  ADMIN
  HR
  USER
}

// =====================================================
// STOCK ERP MODELS (Sage 100 Commercial Clone)
// =====================================================

model Partenaire {
  id_partenaire          Int       @id @default(autoincrement())
  code_partenaire        String    @unique @db.VarChar(50)
  nom_partenaire         String    @db.VarChar(255)
  type_partenaire        String    @db.VarChar(20) // CLIENT, FOURNISSEUR, LES_DEUX
  adresse_email          String?   @db.VarChar(255)
  numero_telephone       String?   @db.VarChar(50)
  numero_fax             String?   @db.VarChar(50)
  url_site_web           String?   @db.VarChar(255)
  adresse_rue            String?
  code_postal            String?   @db.VarChar(20)
  ville                  String?   @db.VarChar(100)
  pays                   String?   @default("Maroc") @db.VarChar(100)
  numero_tva             String?   @db.VarChar(50)
  numero_ice             String?   @db.VarChar(50)
  numero_rc              String?   @db.VarChar(50)
  delai_paiement_jours   Int?      @default(30)
  limite_credit          Decimal?  @db.Decimal(15, 2)
  pourcentage_remise     Decimal?  @default(0) @db.Decimal(5, 2)
  numero_compte_bancaire String?   @db.VarChar(50)
  code_banque            String?   @db.VarChar(20)
  numero_iban            String?   @db.VarChar(50)
  code_swift             String?   @db.VarChar(20)
  est_actif              Boolean   @default(true)
  est_bloque             Boolean   @default(false)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt
  cree_par               String?   @db.Uuid
  modifie_par            String?   @db.Uuid
  compte_collectif       String?   @db.VarChar(20)
  compte_auxiliaire      String?   @db.VarChar(20)

  // Relations
  produits               Produit[]            @relation("FournisseurPrincipal")
  documents_vente        DocVente[]
  affaires_client        Affaire[]
  tarifs_fournisseurs    TarifFournisseur[]
  historique_prix        HistoriquePrixAchat[]

  @@map("partenaires")
  @@index([type_partenaire])
  @@index([est_actif])
}

model CategorieProduit {
  id_categorie           Int       @id @default(autoincrement())
  code_categorie         String    @unique @db.VarChar(50)
  nom_categorie          String    @db.VarChar(255)
  id_categorie_parent    Int?
  description_categorie  String?
  est_actif              Boolean   @default(true)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt

  // Self-relation
  parent                 CategorieProduit?  @relation("CategorieHierarchie", fields: [id_categorie_parent], references: [id_categorie])
  enfants                CategorieProduit[] @relation("CategorieHierarchie")

  // Relations
  produits               Produit[]

  @@map("categories_produits")
  @@index([id_categorie_parent])
}

model Entrepot {
  id_entrepot            Int       @id @default(autoincrement())
  code_entrepot          String    @unique @db.VarChar(50)
  nom_entrepot           String    @db.VarChar(255)
  adresse_entrepot       String?
  ville_entrepot         String?   @db.VarChar(100)
  code_postal_entrepot   String?   @db.VarChar(20)
  capacite_totale_unites Int?
  nom_responsable        String?   @db.VarChar(255)
  email_responsable      String?   @db.VarChar(255)
  telephone_responsable  String?   @db.VarChar(50)
  est_actif              Boolean   @default(true)
  est_entrepot_principal Boolean   @default(false)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt

  // Relations
  niveaux_stock          NiveauStock[]
  mouvements_stock       MouvementStock[]
  documents_entrepot     DocVente[]

  @@map("entrepots")
}

model Produit {
  id_produit                        Int       @id @default(autoincrement())
  code_produit                      String    @unique @db.VarChar(100)
  nom_produit                       String    @db.VarChar(500)
  id_categorie                      Int?
  famille                           String?   @db.VarChar(100)
  description_produit               String?
  code_barre_ean                    String?   @db.VarChar(50)
  unite_mesure                      String    @default("U") @db.VarChar(20)
  poids_kg                          Decimal?  @db.Decimal(10, 3)
  volume_m3                         Decimal?  @db.Decimal(10, 6)
  prix_achat                        Decimal?  @db.Decimal(15, 4)
  prix_dernier_achat                Decimal?  @db.Decimal(15, 4)
  coefficient                       Decimal?  @default(1.0) @db.Decimal(8, 4)
  prix_vente                        Decimal?  @db.Decimal(15, 4)
  prix_gros                         Decimal?  @db.Decimal(15, 4)
  taux_tva                          Decimal?  @default(20.00) @db.Decimal(5, 2)
  type_suivi_stock                  String?   @default("AUCUN") @db.VarChar(20)
  quantite_min_commande             Int?      @default(1)
  niveau_reappro_quantite           Int?      @default(0)
  stock_minimum                     Int?      @default(0)
  stock_maximum                     Int?
  activer_suivi_stock               Boolean   @default(true)
  id_fournisseur_principal          Int?
  reference_fournisseur             String?   @db.VarChar(100)
  delai_livraison_fournisseur_jours Int?
  est_actif                         Boolean   @default(true)
  en_sommeil                        Boolean   @default(false)
  est_abandonne                     Boolean   @default(false)
  date_creation                     DateTime  @default(now())
  date_modification                 DateTime  @default(now()) @updatedAt
  cree_par                          String?   @db.Uuid
  modifie_par                       String?   @db.Uuid
  compte_general_vente              String?   @db.VarChar(20)
  compte_general_achat              String?   @db.VarChar(20)
  code_taxe_vente                   String?   @db.VarChar(10)
  code_taxe_achat                   String?   @db.VarChar(10)

  // Relations
  categorie              CategorieProduit?     @relation(fields: [id_categorie], references: [id_categorie])
  fournisseur_principal  Partenaire?           @relation("FournisseurPrincipal", fields: [id_fournisseur_principal], references: [id_partenaire])
  niveaux_stock          NiveauStock[]
  lignes_documents       LigneDocument[]
  tarifs_fournisseurs    TarifFournisseur[]
  historique_prix        HistoriquePrixAchat[]
  mouvements_stock       MouvementStock[]
  lots_serie             LotSerie[]

  @@map("produits")
  @@index([id_categorie])
  @@index([famille])
  @@index([id_fournisseur_principal])
  @@index([est_actif])
  @@index([code_produit])
}

model TarifFournisseur {
  id_tarif               Int       @id @default(autoincrement())
  id_produit             Int
  id_fournisseur         Int
  reference_fournisseur  String?   @db.VarChar(100)
  prix_achat             Decimal   @db.Decimal(15, 4)
  devise                 String    @default("MAD") @db.VarChar(3)
  date_tarif             DateTime  @default(now()) @db.Date
  quantite_min           Int?      @default(1)
  delai_livraison_jours  Int?
  est_fournisseur_principal Boolean @default(false)
  est_actif              Boolean   @default(true)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt

  // Relations
  produit                Produit    @relation(fields: [id_produit], references: [id_produit], onDelete: Cascade)
  fournisseur            Partenaire @relation(fields: [id_fournisseur], references: [id_partenaire], onDelete: Cascade)

  @@unique([id_produit, id_fournisseur])
  @@map("tarifs_fournisseurs")
  @@index([id_produit])
  @@index([id_fournisseur])
}

model NiveauStock {
  id_stock               Int       @id @default(autoincrement())
  id_produit             Int
  id_entrepot            Int
  quantite_en_stock      Decimal   @default(0) @db.Decimal(15, 3)
  quantite_reservee      Decimal   @default(0) @db.Decimal(15, 3)
  quantite_commandee     Decimal   @default(0) @db.Decimal(15, 3)
  date_dernier_mouvement DateTime?
  type_dernier_mouvement String?   @db.VarChar(50)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt

  // Relations
  produit                Produit   @relation(fields: [id_produit], references: [id_produit], onDelete: Cascade)
  entrepot               Entrepot  @relation(fields: [id_entrepot], references: [id_entrepot], onDelete: Cascade)

  @@unique([id_produit, id_entrepot])
  @@map("niveaux_stock")
  @@index([id_produit])
  @@index([id_entrepot])
}

model Affaire {
  id_affaire             Int       @id @default(autoincrement())
  code_affaire           String    @unique @db.VarChar(50)
  intitule_affaire       String    @db.VarChar(500)
  type_affaire           String    @default("Proposition") @db.VarChar(30)
  statut_affaire         String?   @default("En cours") @db.VarChar(30)
  abrege                 String?   @db.VarChar(100)
  id_client              Int?
  date_debut             DateTime? @db.Date
  date_fin_prevue        DateTime? @db.Date
  date_fin_reelle        DateTime? @db.Date
  budget_prevu           Decimal?  @db.Decimal(15, 2)
  chiffre_affaires       Decimal?  @default(0) @db.Decimal(15, 2)
  marge                  Decimal?  @default(0) @db.Decimal(15, 2)
  taux_remise_moyen      Decimal?  @default(0) @db.Decimal(5, 2)
  notes                  String?
  est_actif              Boolean   @default(true)
  en_sommeil             Boolean   @default(false)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt
  cree_par               String?   @db.Uuid
  modifie_par            String?   @db.Uuid

  // Relations
  client                 Partenaire?      @relation(fields: [id_client], references: [id_partenaire])
  documents_affaire      DocVente[]
  lignes_documents       LigneDocument[]

  @@map("affaires")
  @@index([type_affaire])
  @@index([id_client])
  @@index([est_actif])
}

model DocVente {
  id_document            Int       @id @default(autoincrement())
  numero_document        String    @unique @db.VarChar(50)
  type_document          String    @db.VarChar(30)
  domaine_document       String    @default("VENTE") @db.VarChar(10)
  etat_document          String    @default("Saisi") @db.VarChar(30)
  id_partenaire          Int
  nom_partenaire_snapshot String?  @db.VarChar(255)
  id_affaire             Int?
  numero_affaire         String?   @db.VarChar(50)
  date_document          DateTime  @default(now()) @db.Date
  date_echeance          DateTime? @db.Date
  date_livraison         DateTime? @db.Date
  date_livraison_prevue  DateTime? @db.Date
  montant_ht             Decimal   @default(0) @db.Decimal(15, 2)
  montant_remise_total   Decimal   @default(0) @db.Decimal(15, 2)
  montant_tva_total      Decimal   @default(0) @db.Decimal(15, 2)
  montant_ttc            Decimal   @default(0) @db.Decimal(15, 2)
  solde_du               Decimal   @default(0) @db.Decimal(15, 2)
  code_devise            String    @default("MAD") @db.VarChar(3)
  taux_change            Decimal   @default(1) @db.Decimal(10, 6)
  statut_document        String    @default("BROUILLON") @db.VarChar(20)
  est_entierement_paye   Boolean   @default(false)
  id_entrepot            Int?
  notes_internes         String?
  notes_client           String?
  reference_externe      String?   @db.VarChar(100)
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt
  cree_par               String?   @db.Uuid
  modifie_par            String?   @db.Uuid
  mode_expedition        String?   @db.VarChar(50)
  poids_total_brut       Decimal?  @db.Decimal(10, 3)
  nombre_colis           Int?

  // Relations
  partenaire             Partenaire    @relation(fields: [id_partenaire], references: [id_partenaire])
  affaire                Affaire?      @relation(fields: [id_affaire], references: [id_affaire])
  entrepot               Entrepot?     @relation(fields: [id_entrepot], references: [id_entrepot])
  lignes                 LigneDocument[]

  @@map("documents")
  @@index([type_document])
  @@index([domaine_document])
  @@index([id_partenaire])
  @@index([id_affaire])
  @@index([date_document])
  @@index([statut_document])
}

model LigneDocument {
  id_ligne               Int       @id @default(autoincrement())
  id_document            Int
  numero_ligne           Int
  id_affaire             Int?
  numero_affaire         String?   @db.VarChar(50)
  id_produit             Int
  code_produit_snapshot  String?   @db.VarChar(100)
  nom_produit_snapshot   String?   @db.VarChar(500)
  quantite_commandee     Decimal   @default(0) @db.Decimal(15, 3)
  quantite_livree        Decimal   @default(0) @db.Decimal(15, 3)
  quantite_facturee      Decimal   @default(0) @db.Decimal(15, 3)
  prix_unitaire_ht       Decimal   @db.Decimal(15, 4)
  pourcentage_remise     Decimal   @default(0) @db.Decimal(5, 2)
  taux_tva               Decimal   @default(20.00) @db.Decimal(5, 2)
  montant_remise         Decimal   @default(0) @db.Decimal(15, 2)
  montant_ht             Decimal   @default(0) @db.Decimal(15, 2)
  montant_tva            Decimal   @default(0) @db.Decimal(15, 2)
  montant_ttc            Decimal   @default(0) @db.Decimal(15, 2)
  statut_ligne           String    @default("EN_ATTENTE") @db.VarChar(20)
  notes_ligne            String?
  id_lot                 Int?
  date_creation          DateTime  @default(now())
  date_modification      DateTime  @default(now()) @updatedAt

  // Relations
  document               DocVente  @relation(fields: [id_document], references: [id_document], onDelete: Cascade)
  produit                Produit   @relation(fields: [id_produit], references: [id_produit])
  affaire                Affaire?  @relation(fields: [id_affaire], references: [id_affaire])
  lot                    LotSerie? @relation(fields: [id_lot], references: [id_lot])

  @@map("lignes_documents")
  @@index([id_document])
  @@index([id_produit])
  @@index([id_affaire])
}

model HistoriquePrixAchat {
  id_historique          Int       @id @default(autoincrement())
  id_produit             Int
  id_fournisseur         Int?
  id_document            Int?
  prix_achat             Decimal   @db.Decimal(15, 4)
  quantite               Decimal?  @db.Decimal(15, 3)
  date_achat             DateTime  @default(now()) @db.Date
  notes                  String?
  date_creation          DateTime  @default(now())

  // Relations
  produit                Produit    @relation(fields: [id_produit], references: [id_produit], onDelete: Cascade)
  fournisseur            Partenaire? @relation(fields: [id_fournisseur], references: [id_partenaire])

  @@map("historique_prix_achats")
  @@index([id_produit])
  @@index([date_achat])
}

model MouvementStock {
  id_mouvement           Int       @id @default(autoincrement())
  id_produit             Int
  id_entrepot            Int
  id_document            Int?
  id_ligne_document      Int?
  type_mouvement         String    @db.VarChar(30)
  quantite               Decimal   @db.Decimal(15, 3)
  date_mouvement         DateTime  @default(now())
  reference_document     String?   @db.VarChar(50)
  motif                  String?
  cree_par               String?   @db.Uuid
  id_lot                 Int?
  date_creation          DateTime  @default(now())

  // Relations
  produit                Produit   @relation(fields: [id_produit], references: [id_produit])
  entrepot               Entrepot  @relation(fields: [id_entrepot], references: [id_entrepot])

  @@map("mouvements_stock")
  @@index([id_produit])
  @@index([id_entrepot])
  @@index([date_mouvement])
}

model LotSerie {
  id_lot                 Int       @id @default(autoincrement())
  code_lot               String    @db.VarChar(50)
  id_produit             Int
  date_fabrication       DateTime? @db.Date
  date_peremption        DateTime? @db.Date
  numero_serie_unique    String?   @db.VarChar(100)
  quantite_initiale      Decimal?  @db.Decimal(15, 3)
  quantite_actuelle      Decimal   @default(0) @db.Decimal(15, 3)
  est_actif              Boolean   @default(true)
  date_creation          DateTime  @default(now())

  // Relations
  produit                Produit   @relation(fields: [id_produit], references: [id_produit], onDelete: Cascade)
  lignes_documents       LigneDocument[]

  @@unique([code_lot, id_produit])
  @@map("lots_serie")
}

model TarifExceptionnel {
  id_tarif_ex            Int       @id @default(autoincrement())
  id_produit             Int?
  id_client              Int?
  quantite_min           Int?      @default(1)
  prix_vente_fixe        Decimal?  @db.Decimal(15, 4)
  remise_pourcentage     Decimal?  @db.Decimal(5, 2)
  date_debut             DateTime? @db.Date
  date_fin               DateTime? @db.Date
  priorite               Int?      @default(0)
  date_creation          DateTime  @default(now())

  @@map("tarifs_exceptionnels")
}
