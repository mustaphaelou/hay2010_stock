# =============================================================================
# HAY2010 STOCK APPLICATION - DOCKER ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.docker and fill in the values.
# Generate secrets with: openssl rand -base64 48
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generate-with-openssl-rand-base64-48>
POSTGRES_DB=hay2010_db

# -----------------------------------------------------------------------------
# Database URL
# URL-encode the password if it contains special characters:
#   + = %2B, / = %2F, = = %3D, @ = %40, : = %3A
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<url-encoded-password>@postgres:5432/hay2010_db?connection_limit=5&pool_timeout=10

# -----------------------------------------------------------------------------
# Redis Configuration
# URL-encode the password for REDIS_URL
# -----------------------------------------------------------------------------
REDIS_PASSWORD=<generate-with-openssl-rand-base64-48>
REDIS_URL=redis://:<url-encoded-password>@redis:6379/0

# -----------------------------------------------------------------------------
# JWT Secret
# -----------------------------------------------------------------------------
JWT_SECRET=<generate-with-openssl-rand-base64-64>
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# Application Version (used for image tagging)
# Matches package.json version by default
# -----------------------------------------------------------------------------
APP_VERSION=0.1.1

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=HAY2010 Stock
NEXT_PUBLIC_COMPANY_NAME=HAY2010

# -----------------------------------------------------------------------------
# Security Configuration (override for production)
# -----------------------------------------------------------------------------
SECURE_COOKIES=false
LOCKOUT_FAIL_CLOSED=false
RATE_LIMIT_FAIL_CLOSED=false

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=hay2010_stock

# -----------------------------------------------------------------------------
# Optional: Port overrides
# -----------------------------------------------------------------------------
# APP_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
