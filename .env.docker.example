# =============================================================================
# HAY2010 STOCK APPLICATION - DOCKER ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.docker and fill in your values
# NEVER commit .env.docker to version control

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<GENERATE_WITH:_PowerShell_or_openssl>
POSTGRES_DB=hay2010_db

# -----------------------------------------------------------------------------
# Database URL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<PASSWORD>@postgres:5432/hay2010_db?connection_limit=5&pool_timeout=10

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_PASSWORD=<GENERATE_WITH:_openssl_rand_-base64_32>

# -----------------------------------------------------------------------------
# JWT Secret
# -----------------------------------------------------------------------------
JWT_SECRET=<GENERATE_WITH:_PowerShell_or_openssl>
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="HAY2010 Stock"
NEXT_PUBLIC_COMPANY_NAME="HAY2010"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
SECURE_COOKIES=true
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=hay2010_stock

# -----------------------------------------------------------------------------
# Docker Secrets Support (Production)
# -----------------------------------------------------------------------------
# Secrets can be provided via Docker Secrets for production deployments
# Set *_FILE variables to point to secret files mounted in the container
# Example:
#   JWT_SECRET_FILE=/run/secrets/jwt_secret
#   POSTGRES_PASSWORD_FILE=/run/secrets/db_password
#   REDIS_PASSWORD_FILE=/run/secrets/redis_password
#
# The application will automatically read from _FILE suffixed variables
# when available, falling back to direct env vars if not present.
# -----------------------------------------------------------------------------
