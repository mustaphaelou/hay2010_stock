{
  "name": "hay2010_stock",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:backup": "./scripts/backup.sh",
    "db:restore": "./scripts/restore.sh",
    "security:validate-headers": "node scripts/validate-security-headers.js http://localhost:3000",
    "test:security": "vitest run src/__tests__/middleware/security.test.ts",
    "test:errors": "vitest run src/__tests__/lib/errors.test.ts",
    "test:metrics": "vitest run src/__tests__/lib/monitoring/business-metrics.test.ts",
    "test:health": "vitest run src/__tests__/api/health.test.ts",
    "test:all": "vitest run",
    "docker:build": "docker build -t hay2010_stock:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:local:up": "docker-compose -f docker-compose.local.yml up -d",
    "docker:local:down": "docker-compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker-compose -f docker-compose.local.yml logs -f",
    "docker:local:build": "docker build -f Dockerfile.local -t hay2010_stock:local .",
    "docker:local:restart": "docker-compose -f docker-compose.local.yml restart",
    "docker:local:status": "docker-compose -f docker-compose.local.yml ps",
    "docker:local:psql": "docker exec -it hay2010_postgres psql -U postgres -d hay2010_db",
    "docker:local:redis": "docker exec -it hay2010_redis redis-cli",
    "docker:local:migrate": "docker-compose -f docker-compose.local.yml run --rm migrate",
    "docker:local:seed": "docker-compose -f docker-compose.local.yml exec app npm run db:seed",
    "k8s:apply:staging": "kubectl apply -k k8s/overlays/staging",
    "k8s:apply:production": "kubectl apply -k k8s/overlays/production"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hugeicons/core-free-icons": "^3.0.0",
    "@hugeicons/react": "^1.1.3",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "input-otp": "^1.4.2",
    "ioredis": "^5.10.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.562.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "recharts": "^2.15.4",
    "shadcn": "^3.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.0.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.8"
  }
}
