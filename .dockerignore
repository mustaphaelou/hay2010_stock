# ============================================
# HAY2010 Stock Application - Docker Ignore
# Version: 3.0 (Optimized for Docker Compose)
# ============================================
# Excludes all files not needed for Docker build
# Reduces build context size and improves stability
# ============================================

# =====================================================
# DEPENDENCIES (regenerate in container)
# =====================================================
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
yarn.lock
pnpm-lock.yaml
bun.lockb

# =====================================================
# BUILD OUTPUT (regenerate in container)
# =====================================================
.next
out
build
dist
.turbo
.cache

# =====================================================
# TESTING (not needed in production)
# =====================================================
coverage
.nyc_output
__tests__
tests
src/__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
vitest.config.ts
jest.config.*
jest.setup.*

# =====================================================
# TYPESCRIPT BUILD ARTIFACTS
# =====================================================
*.tsbuildinfo
.tsbuildinfo

# =====================================================
# ENVIRONMENT FILES (inject via Docker Secrets)
# =====================================================
.env
.env.*
!.env.example
!.env.docker.example
.env.local
.env.docker

# =====================================================
# IDE AND EDITOR FILES
# =====================================================
.idea
.vscode
.cursor
.kilo
.kilocode
*.swp
*.swo
*~

# =====================================================
# OS GENERATED FILES
# =====================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =====================================================
# VERSION CONTROL
# =====================================================
.git
.gitignore
.gitattributes

# =====================================================
# DOCKER CONFIGURATION FILES
# =====================================================
Dockerfile
docker-compose*.yml
docker-compose*.yaml
.dockerignore
.docker

# Note: docker-entrypoint.sh is NOT ignored - needed for container startup

# =====================================================
# DOCUMENTATION (not needed in container)
# =====================================================
README.md
CHANGELOG.md
SETUP.md
DEPLOY.md
TROUBLESHOOTING.md
COOLIFY_DEPLOYMENT.md
docs/
plans/

# =====================================================
# CI/CD CONFIGURATION (not needed)
# =====================================================
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.gitlab/

# =====================================================
# KUBERNETES CONFIGS (removed for Docker Compose only)
# =====================================================
k8s/
helm/
.helm/

# =====================================================
# MONITORING STACK (removed for stability)
# =====================================================
monitoring/

# =====================================================
# PRISMA GENERATED (regenerate in container)
# =====================================================
lib/generated/prisma/

# =====================================================
# LOGS AND TEMPORARY FILES
# =====================================================
logs
*.log
*.pid
*.seed
*.pid.lock
tmp
temp
.tmp

# =====================================================
# DEVELOPMENT SCRIPTS (not needed in production)
# =====================================================
scripts/
deploy.sh

# =====================================================
# SECRETS DIRECTORY (use Docker Secrets)
# =====================================================
secrets/

# =====================================================
# BACKUP FILES
# =====================================================
backups/
*.backup
*.bak

# =====================================================
# TERRAFORM AND INFRASTRUCTURE AS CODE
# =====================================================
.terraform
*.tfstate
*.tfstate.*
*.tfvars
*.tf

# =====================================================
# MISCELLANEOUS
# =====================================================
errors.txt
tsc_errors.log
*.orig
*.patch
